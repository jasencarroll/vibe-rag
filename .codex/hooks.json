{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh -lc 'exec \"$(git rev-parse --show-toplevel)/scripts/run-vibe-rag\" hook-session-start --format codex'",
            "statusMessage": "Loading vibe-rag session context",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
