{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["vibe-rag"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/run-vibe-rag hook-session-start --format claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/claude_pretool_guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/claude_posttool_pytest.py",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
