{
  "mcpServers": {
    "vibe-rag": {
      "command": "vibe-rag",
      "args": ["serve"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "vibe-rag hook-session-start --format gemini",
            "timeout": 30000,
            "description": "Load vibe-rag session context on startup"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "vibe-rag hook-session-start --format gemini",
            "timeout": 30000,
            "description": "Load vibe-rag session context on resume"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "vibe-rag hook-session-start --format gemini",
            "timeout": 30000,
            "description": "Load vibe-rag session context after clear"
          }
        ]
      }
    ]
  }
}
